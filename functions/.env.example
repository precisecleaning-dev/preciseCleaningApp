# ==== Copia este archivo como ".env" dentro de functions/ y ajusta los valores ====

# ID del calendario a sincronizar (el calendario principal de la cuenta es su email)
CALENDAR_ID=account@precisecleaningtx.com

# Email que recibe los reportes de Quality Check terminados.
# Si se deja vacío, se usa el email guardado en settings_company/main.
QC_REPORT_EMAIL=

# URL pública del webhook (se conoce DESPUÉS del primer deploy)
CALENDAR_WEBHOOK_URL=
